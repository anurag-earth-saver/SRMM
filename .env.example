# Server
PORT=3001
NODE_ENV=development

# Upload limits
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# CORS — comma-separated origins, or * for Vercel
CORS_ORIGIN=http://localhost:5173

# Client (Vite) — leave empty for same-origin /api on Vercel
# VITE_API_BASE=/api

# Vercel sets VERCEL=1 automatically

# Future: Database
# DATABASE_URL=postgresql://user:password@localhost:5432/brsr_srmm

# Future: Authentication
# JWT_SECRET=your-secret-key
# JWT_EXPIRY=7d
